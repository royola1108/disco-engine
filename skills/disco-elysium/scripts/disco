#!/usr/bin/env node
// disco — CLI for the Disco Elysium text-game engine.
// Talks to the VPS via REST API. Each AI gets its own player state.

const fs = require("fs");
const path = require("path");
const os = require("os");
const crypto = require("crypto");

const DEFAULT_SERVER = "https://disco.royola.dev";
const SERVER = (process.env.DISCO_SERVER || DEFAULT_SERVER).replace(/\/$/, "");
const API = SERVER + "/api";
const ID_FILE = path.join(os.homedir(), ".disco-player-id");
const TOKEN_FILE = path.join(os.homedir(), ".disco-token");

function getToken() {
  // env var overrides file
  if (process.env.DISCO_TOKEN) return process.env.DISCO_TOKEN;
  try { return fs.readFileSync(TOKEN_FILE, "utf-8").trim(); } catch { return ""; }
}

function getPlayerId() {
  try { return fs.readFileSync(ID_FILE, "utf-8").trim(); }
  catch { return null; }
}

function ensurePlayerId() {
  let id = getPlayerId();
  if (!id) {
    id = crypto.randomBytes(4).toString("hex");
    fs.writeFileSync(ID_FILE, id, "utf-8");
    console.error(`[disco] New player ID created: ${id}`);
  }
  return id;
}

async function callApi(tool, args = {}) {
  const playerId = ensurePlayerId();
  const token = getToken();
  const headers = { "content-type": "application/json", "X-Player-Id": playerId };
  if (token) headers["X-Auth-Token"] = token;
  const res = await fetch(`${API}/${tool}`, {
    method: "POST",
    headers,
    body: JSON.stringify(args),
  });
  if (res.status === 401) {
    console.error("Unauthorized: invalid or missing token.");
    console.error(`Set your token: echo 'YOUR_TOKEN' > ~/.disco-token`);
    console.error("Or:     DISCO_TOKEN=YOUR_TOKEN disco start");
    process.exit(1);
  }
  const text = await res.text();
  if (!res.ok) throw new Error(text);
  return text;
}

const commands = {
  async token(args) {
    const t = args[0];
    if (!t) {
      const existing = getToken();
      if (existing) console.log(`Token is set (${existing.slice(0,4)}...)`);
      else console.log("No token set. Usage: disco token YOUR_TOKEN");
      return;
    }
    fs.writeFileSync(TOKEN_FILE, t, "utf-8");
    console.log(`Token saved to ~/.disco-token`);
  },

  async start(args) {
    const sceneId = args[0] ? parseInt(args[0], 10) : undefined;
    console.log(await callApi("start", { sceneId }));
  },

  async play(args) {
    const opts = {};
    const choices = [];
    while (args.length) {
      const a = args.shift();
      if (a === "--no-auto") opts.autoAdvance = false;
      else if (a === "--stop") opts.stopAt = args.shift().split(",");
      else if (a === "--max") opts.maxSteps = parseInt(args.shift(), 10);
      else if (/^\d+$/.test(a)) choices.push(parseInt(a, 10));
    }
    if (choices.length) opts.choices = choices;
    console.log(await callApi("play", opts));
  },

  async status() { console.log(await callApi("status")); },
  async history(args) { console.log(await callApi("history", { count: args[0] ? parseInt(args[0], 10) : 20 })); },
  async save(args) { console.log(await callApi("save", { slot: args[0] || "auto", label: args[1] || "" })); },
  async load(args) { console.log(await callApi("load", { slot: args[0] || "auto" })); },
  async saves() { console.log(await callApi("saves")); },

  async scenes(args) {
    const opts = {};
    if (args[0] && args[0] !== "--all") opts.search = args[0];
    opts.limit = args[0] === "--all" ? 1428 : 20;
    console.log(await callApi("scenes", opts));
  },

  async players() { console.log(await callApi("players")); },

  async whoami() {
    const id = getPlayerId();
    if (id) console.log(`You are player: ${id}`);
    else console.log("No player ID yet. Run any command to create one.");
  },

  async reset() {
    try { fs.unlinkSync(ID_FILE); } catch {}
    console.log("Player ID cleared. Next command will create a new one.");
  },

  async help() {
    console.log(`
disco — play Disco Elysium via text

  disco start [SCENE_ID]     Start a new game (default: scene 142 — Whirling-in-Rags, Day 1)
  disco play [CHOICE...]     Advance. Pass choice indices: disco play 2
    --no-auto                 Don't auto-advance through single-option nodes
    --stop check,scene_end    Stop conditions (comma-separated)
    --max 50                  Max steps per call
  disco status                Current game state snapshot
  disco history [N]           Recent N trace entries (default 20)
  disco save [SLOT] [LABEL]   Save to slot (default: auto)
  disco load [SLOT]           Load from slot
  disco saves                 List all save slots
  disco scenes [SEARCH]       List scenes, optionally filter by title
  disco players               List all active players on the server
  disco whoami                Show your player ID
  disco reset                 Reset your player ID (start a fresh game)
  disco token [TOKEN]         Set or check your access token
  disco help                  This message

Your player ID is stored in ~/.disco-player-id.
Your access token is stored in ~/.disco-token (or set DISCO_TOKEN env var).
Each AI/player gets independent game state. Use DISCO_SERVER to override.
Server: ${SERVER}
`);
  },
};

async function main() {
  const [cmd, ...args] = process.argv.slice(2);
  if (!cmd || cmd === "help" || cmd === "--help" || cmd === "-h") {
    await commands.help();
    return;
  }
  const fn = commands[cmd];
  if (!fn) {
    console.error(`Unknown command: ${cmd}. Run \`disco help\`.`);
    process.exit(1);
  }
  try {
    await fn(args);
  } catch (e) {
    console.error(`Error: ${e.message}`);
    process.exit(1);
  }
}

main();
